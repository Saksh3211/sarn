{
  "comments": {
    "lineComment": "--",
    "blockComment": ["--[[", "]]"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'",  "close": "'",  "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["{", "}"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\b(then|do|repeat)\\b",
    "decreaseIndentPattern": "^\\s*(end|else|elseif|until)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "\\b(then|do|repeat)\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(end|else|elseif|until)\\b",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}