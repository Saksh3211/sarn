{
  "Strict Mode Header": {
    "prefix": "!!strict",
    "body": ["--!!type:strict", "--!!mem:man", "$0"],
    "description": "Strict mode + manual memory directives"
  },

  "NonStrict Mode Header": {
    "prefix": "!!nonstrict",
    "body": ["--!!type:nonstrict", "$0"],
    "description": "Non-strict mode directive"
  },

  "Main Function": {
    "prefix": "main",
    "body": ["function main(): int", "    $0", "    return 0", "end"],
    "description": "Entry-point main(): int"
  },

  "Function Declaration": {
    "prefix": "fn",
    "body": [
      "function ${1:name}(${2:param}: ${3:int}): ${4:void}",
      "    $0",
      "end"
    ],
    "description": "Function declaration"
  },

  "Exported Function": {
    "prefix": "efn",
    "body": [
      "export function ${1:name}(${2:param}: ${3:int}): ${4:void}",
      "    $0",
      "end"
    ],
    "description": "Exported function declaration"
  },

  "Struct Method": {
    "prefix": "method",
    "body": [
      "function ${1:TypeName}.${2:method}(self: ${1:TypeName}$3): ${4:void}",
      "    $0",
      "end"
    ],
    "description": "Struct method  (function TypeName.method)"
  },

  "Type Declaration": {
    "prefix": "struct",
    "body": [
      "type ${1:Name} = {",
      "    ${2:field}: ${3:int},",
      "    $0",
      "}"
    ],
    "description": "Record/struct type declaration"
  },

  "Enum Declaration": {
    "prefix": "enum",
    "body": ["enum ${1:Name} = { ${2:A} = 0, ${3:B}, $0 }"],
    "description": "Enum declaration"
  },

  "Local Variable": {
    "prefix": "loc",
    "body": ["local ${1:name}: ${2:int} = ${3:0}"],
    "description": "Typed local variable"
  },

  "Const Declaration": {
    "prefix": "cst",
    "body": ["const ${1:NAME}: ${2:int} = ${3:0}"],
    "description": "Constant declaration"
  },

  "Global Variable": {
    "prefix": "glob",
    "body": ["global ${1:name}: ${2:int} = ${3:0}"],
    "description": "Global variable declaration"
  },

  "Import Module": {
    "prefix": "imp",
    "body": ["import ${1|math,os,io,string,stdata,stdgui|}"],
    "description": "Import a built-in module"
  },

  "If Statement": {
    "prefix": "if",
    "body": ["if ${1:condition} then", "    $0", "end"],
    "description": "If statement"
  },

  "If-Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} then",
      "    ${2:-- true branch}",
      "else",
      "    $0",
      "end"
    ],
    "description": "If-else statement"
  },

  "If-ElseIf-Else": {
    "prefix": "ifee",
    "body": [
      "if ${1:cond1} then",
      "    ${2}",
      "elseif ${3:cond2} then",
      "    ${4}",
      "else",
      "    $0",
      "end"
    ],
    "description": "If-elseif-else chain"
  },

  "While Loop": {
    "prefix": "while",
    "body": ["while ${1:condition} do", "    $0", "end"],
    "description": "While loop"
  },

  "Numeric For": {
    "prefix": "forn",
    "body": ["for ${1:i} = ${2:0}, ${3:10} - 1, 1 do", "    $0", "end"],
    "description": "Numeric for loop (inclusive stop)"
  },

  "C-Style For": {
    "prefix": "forc",
    "body": [
      "for ${1:i} = ${2:0}, ${1:i} < ${3:10}, ${1:i} + 1 do",
      "    $0",
      "end"
    ],
    "description": "C-style for loop"
  },

  "Repeat-Until": {
    "prefix": "rep",
    "body": ["repeat", "    $0", "until ${1:condition}"],
    "description": "Repeat-until loop"
  },

  "Alloc + Defer Free": {
    "prefix": "alloc",
    "body": [
      "local ${1:buf}: ptr<${2:int}> = alloc_typed(${2:int}, ${3:N})",
      "if ${1:buf} == null then panic(\"alloc failed\") end",
      "defer free(${1:buf})",
      "$0"
    ],
    "description": "Allocate typed buffer with deferred free"
  },

  "Extern Function": {
    "prefix": "ext",
    "body": [
      "extern function ${1:name}(${2:param}: ${3:int}): ${4:void}"
    ],
    "description": "Extern C function declaration"
  },

  "Panic Check": {
    "prefix": "pnc",
    "body": ["if ${1:condition} then", "    panic(\"${2:error message}\")", "end"],
    "description": "Conditional panic"
  },

  "Window Main Loop (stdgui)": {
    "prefix": "winmain",
    "body": [
      "--!!type:strict",
      "--!!mem:man",
      "import stdgui",
      "",
      "function main(): int",
      "    window.init(${1:800}, ${2:600}, \"${3:S Lua App}\", 60)",
      "",
      "    while window.should_close() == 0 do",
      "        window.begin_drawing()",
      "        window.clear(${4:20}, ${5:22}, ${6:30}, 255)",
      "",
      "        $0",
      "",
      "        window.end_drawing()",
      "    end",
      "",
      "    window.close()",
      "    return 0",
      "end"
    ],
    "description": "Full window application skeleton"
  },

  "Draw Rectangle": {
    "prefix": "drect",
    "body": ["draw.rect(${1:x}, ${2:y}, ${3:w}, ${4:h}, ${5:255}, ${6:255}, ${7:255}, ${8:255})"],
    "description": "draw.rect(x, y, w, h, r, g, b, a)"
  },

  "Draw Text": {
    "prefix": "dtxt",
    "body": ["draw.text(\"${1:text}\", ${2:x}, ${3:y}, ${4:24}, ${5:255}, ${6:255}, ${7:255}, 255)"],
    "description": "draw.text(text, x, y, size, r, g, b, a)"
  },

  "UI Button": {
    "prefix": "ubtn",
    "body": [
      "if ui.button(${1:x}, ${2:y}, ${3:120}, ${4:36}, \"${5:Click Me}\") == 1 then",
      "    $0",
      "end"
    ],
    "description": "UI button with click handler"
  },

  "Multi-Return Function": {
    "prefix": "fnmr",
    "body": [
      "function ${1:name}(${2:a}: ${3:int}, ${4:b}: ${5:int}): ${6:int}, ${7:int}",
      "    return $0, ${8:0}",
      "end"
    ],
    "description": "Function with multiple return values"
  },

  "Multi-Local Unpack": {
    "prefix": "locm",
    "body": ["local ${1:a}, ${2:b} = ${3:func()}"],
    "description": "Unpack multiple return values"
  }
}
