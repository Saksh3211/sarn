{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "S Lua",
  "scopeName": "source.sarn",
  "fileTypes": ["sarn"],
  "patterns": [
    { "include": "#directive" },
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#string-double" },
    { "include": "#string-single" },
    { "include": "#function-method-decl" },
    { "include": "#function-decl" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-memory" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#builtin-modules" },
    { "include": "#number-float" },
    { "include": "#number-int" },
    { "include": "#operators" },
    { "include": "#function-call" }
  ],

  "repository": {

    "directive": {
      "match": "^--!!.*$",
      "name": "keyword.other.directive.sarn",
      "captures": {
        "0": { "name": "markup.bold keyword.other.directive.sarn" }
      }
    },

    "block-comment": {
      "name": "comment.block.sarn",
      "begin": "--\\[\\[",
      "end": "\\]\\]"
    },

    "line-comment": {
      "name": "comment.line.double-dash.sarn",
      "match": "--.*$"
    },

    "string-double": {
      "name": "string.quoted.double.sarn",
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.sarn" } },
      "end": "\"",
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.sarn" } },
      "patterns": [
        { "name": "constant.character.escape.sarn", "match": "\\\\." }
      ]
    },

    "string-single": {
      "name": "string.quoted.single.sarn",
      "begin": "'",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.sarn" } },
      "end": "'",
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.sarn" } },
      "patterns": [
        { "name": "constant.character.escape.sarn", "match": "\\\\." }
      ]
    },

    "function-method-decl": {
      "comment": "function TypeName.method(params): RetType",
      "match": "\\b(function)\\s+([A-Z][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.function.sarn" },
        "2": { "name": "entity.name.type.sarn" },
        "3": { "name": "entity.name.function.sarn" }
      }
    },

    "function-decl": {
      "comment": "function name(params): RetType",
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.function.sarn" },
        "2": { "name": "entity.name.function.sarn" }
      }
    },

    "keywords-control": {
      "name": "keyword.control.sarn",
      "match": "\\b(if|then|else|elseif|end|for|while|do|repeat|until|return|break|continue|and|or|not)\\b"
    },

    "keywords-declaration": {
      "name": "keyword.declaration.sarn",
      "match": "\\b(local|const|global|type|extern|export|import|enum|defer|in|comptime|module)\\b"
    },

    "keywords-memory": {
      "name": "keyword.operator.memory.sarn",
      "match": "\\b(alloc|free|alloc_typed|stack_alloc|deref|store|addr|cast|ptr_cast|panic|typeof|sizeof)\\b"
    },

    "constants": {
      "name": "constant.language.sarn",
      "match": "\\b(null|true|false)\\b"
    },

    "types": {
      "name": "storage.type.primitive.sarn",
      "match": "\\b(int|int8|int16|int32|int64|uint8|uint16|uint32|uint64|number|float|double|string|bool|void|any|ptr|char|byte|table)\\b"
    },

    "builtin-modules": {
      "patterns": [
        {
          "comment": "Highlight module name before a dot",
          "match": "\\b(math|os|io|string|stdata|window|draw|input|ui|font)(?=\\.)",
          "name": "support.class.module.sarn"
        },
        {
          "comment": "Standalone module name or print",
          "match": "\\b(print|math|os|io|string|stdata|window|draw|input|ui|font)\\b",
          "name": "support.function.builtin.sarn"
        }
      ]
    },

    "number-float": {
      "name": "constant.numeric.float.sarn",
      "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?\\b|\\.\\d+([eE][+-]?\\d+)?\\b|\\b\\d+[eE][+-]?\\d+\\b"
    },

    "number-int": {
      "name": "constant.numeric.integer.sarn",
      "match": "\\b\\d+\\b"
    },

    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.sarn",  "match": "==|~=|<=|>=|<(?!<)|>(?!>)" },
        { "name": "keyword.operator.concat.sarn",      "match": "\\.\\." },
        { "name": "keyword.operator.arrow.sarn",       "match": "->" },
        { "name": "keyword.operator.bitwise.sarn",     "match": "<<|>>|[&|~^]" },
        { "name": "keyword.operator.arithmetic.sarn",  "match": "[+\\-*/%]" },
        { "name": "keyword.operator.assignment.sarn",  "match": "(?<![=~<>!])=(?!=)" }
      ]
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.call.sarn"
    }
  }
}
