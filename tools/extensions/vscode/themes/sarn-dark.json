{
  "name": "S Lua Dark",
  "type": "dark",
  "colors": {
    "editor.background":                "#1e1e2e",
    "editor.foreground":                "#cdd6f4",
    "editorLineNumber.foreground":      "#45475a",
    "editorLineNumber.activeForeground":"#bac2de",
    "editor.selectionBackground":       "#45475a80",
    "editor.lineHighlightBackground":   "#313244",
    "editorCursor.foreground":          "#f5c2e7",
    "editorWhitespace.foreground":      "#45475a",
    "editorIndentGuide.background":     "#313244",
    "editorIndentGuide.activeBackground":"#585b70",

    "activityBar.background":           "#181825",
    "activityBar.foreground":           "#cdd6f4",
    "sideBar.background":               "#181825",
    "sideBar.foreground":               "#cdd6f4",
    "sideBarTitle.foreground":          "#cba6f7",
    "statusBar.background":             "#181825",
    "statusBar.foreground":             "#cdd6f4",
    "titleBar.activeBackground":        "#181825",
    "titleBar.activeForeground":        "#cdd6f4",
    "tab.activeBackground":             "#1e1e2e",
    "tab.inactiveBackground":           "#181825",
    "tab.activeForeground":             "#cdd6f4",

    "editorError.foreground":           "#f38ba8",
    "editorWarning.foreground":         "#f9e2af",
    "editorInfo.foreground":            "#89b4fa",
    "editorError.border":               "#f38ba800",
    "editorWarning.border":             "#f9e2af00",

    "terminal.background":              "#1e1e2e",
    "terminal.foreground":              "#cdd6f4",
    "terminal.ansiBrightRed":           "#f38ba8",
    "terminal.ansiBrightGreen":         "#a6e3a1",
    "terminal.ansiBrightYellow":        "#f9e2af",
    "terminal.ansiBrightBlue":          "#89b4fa",
    "terminal.ansiCyan":                "#94e2d5",
    "terminal.ansiBrightCyan":          "#89dceb"
  },

  "tokenColors": [
    {
      "comment": "── Directives (--!!type:strict etc.) ────────────────────────",
      "scope": "keyword.other.directive.sarn",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold italic"
      }
    },

    {
      "comment": "── Comments ─────────────────────────────────────────────────",
      "scope": ["comment.line.double-dash.sarn", "comment.block.sarn"],
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },

    {
      "comment": "── Strings ──────────────────────────────────────────────────",
      "scope": [
        "string.quoted.double.sarn",
        "string.quoted.single.sarn"
      ],
      "settings": { "foreground": "#a6e3a1" }
    },
    {
      "scope": "constant.character.escape.sarn",
      "settings": { "foreground": "#cba6f7" }
    },
    {
      "scope": "punctuation.definition.string.begin.sarn",
      "settings": { "foreground": "#a6e3a1" }
    },
    {
      "scope": "punctuation.definition.string.end.sarn",
      "settings": { "foreground": "#a6e3a1" }
    },

    {
      "comment": "── Control keywords  (if/while/for/return/…) ────────────────",
      "scope": "keyword.control.sarn",
      "settings": {
        "foreground": "#cba6f7",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── Declaration keywords (local/const/function/type/import/…) ",
      "scope": "keyword.declaration.sarn",
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── function keyword inside decl (same style as declaration) ─",
      "scope": "keyword.declaration.function.sarn",
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── Memory / special keywords (alloc/deref/cast/panic/…) ─────",
      "scope": "keyword.operator.memory.sarn",
      "settings": {
        "foreground": "#fab387",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── Types (int/number/string/ptr/…) ──────────────────────────",
      "scope": "storage.type.primitive.sarn",
      "settings": {
        "foreground": "#89dceb",
        "fontStyle": "italic"
      }
    },

    {
      "comment": "── Constants (null/true/false) ───────────────────────────────",
      "scope": "constant.language.sarn",
      "settings": {
        "foreground": "#fab387",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── Built-in module names (math/io/os/…) ─────────────────────",
      "scope": ["support.class.module.sarn", "support.function.builtin.sarn"],
      "settings": { "foreground": "#94e2d5" }
    },

    {
      "comment": "── Declared function names ───────────────────────────────────",
      "scope": "entity.name.function.sarn",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    },

    {
      "comment": "── Type names in method decl (TypeName.method) ──────────────",
      "scope": "entity.name.type.sarn",
      "settings": {
        "foreground": "#89dceb",
        "fontStyle": "italic bold"
      }
    },

    {
      "comment": "── Function calls ────────────────────────────────────────────",
      "scope": "entity.name.function.call.sarn",
      "settings": { "foreground": "#89b4fa" }
    },

    {
      "comment": "── Numbers ───────────────────────────────────────────────────",
      "scope": [
        "constant.numeric.integer.sarn",
        "constant.numeric.float.sarn"
      ],
      "settings": { "foreground": "#fab387" }
    },

    {
      "comment": "── Comparison operators ──────────────────────────────────────",
      "scope": "keyword.operator.comparison.sarn",
      "settings": { "foreground": "#f2cdcd" }
    },
    {
      "comment": "── Arithmetic operators ──────────────────────────────────────",
      "scope": "keyword.operator.arithmetic.sarn",
      "settings": { "foreground": "#bac2de" }
    },
    {
      "comment": "── Concat (..) and arrow (->) ───────────────────────────────",
      "scope": [
        "keyword.operator.concat.sarn",
        "keyword.operator.arrow.sarn"
      ],
      "settings": { "foreground": "#f2cdcd" }
    },
    {
      "comment": "── Bitwise operators ─────────────────────────────────────────",
      "scope": "keyword.operator.bitwise.sarn",
      "settings": { "foreground": "#f2cdcd" }
    },
    {
      "comment": "── Assignment (=) ────────────────────────────────────────────",
      "scope": "keyword.operator.assignment.sarn",
      "settings": { "foreground": "#cdd6f4" }
    }
  ]
}
